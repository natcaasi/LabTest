# Database
DATABASE_URL=./data/todos.db

# Authentication - WebAuthn
JWT_SECRET=your-secret-key-change-me-in-production-32-characters-min
RP_ID=localhost
RP_NAME=Todo App
RP_ORIGIN=http://localhost:3000

# Optional: Timezone (defaults to Asia/Singapore)
TZ=Asia/Singapore

# Railway deployment
RAILWAY_VOLUME_MOUNT_PATH=/data
PORT=3000
NODE_ENV=production
